# === Telegram ===
# Токен бота от @BotFather
TG_BOT_TOKEN=your_telegram_bot_token_here
# ID чата или пользователя для уведомлений (можно получить у @userinfobot)
TG_CHAT_ID=your_telegram_chat_id

# === Яндекс Маркет (BODY KULT) ===
# API-ключ из кабинета продавца: Настройки → API и модули → Отправка запросов Маркету
YM_API_KEY=your_yandex_market_api_key
# ID кампаний (магазинов) BODY KULT через запятую
# Узнать: GET /campaigns или в ЛК → Настройки → API и модули → Идентификатор кампании
YM_CAMPAIGN_IDS=12345678,87654321
# Период проверки новых заказов (в секундах)
YM_CHECK_INTERVAL=60

# === RetailCRM (BUTONI) ===
# URL вашей CRM (например: https://butoni.retailcrm.ru)
RCRM_URL=https://your-domain.retailcrm.ru
# API-ключ: Настройки → Интеграция → Ключи доступа к API
RCRM_API_KEY=your_retailcrm_api_key
# Период проверки новых заказов (в секундах)
RCRM_CHECK_INTERVAL=60
